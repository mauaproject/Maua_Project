Options -Indexes -MultiViews

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(?:css|js|svg|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(?:png|jpe?g|mp4)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

RewriteEngine On

# Jangan arahkan endpoint PHP dan file upload ke React.
RewriteRule ^api(?:/|$) - [L]
RewriteRule ^uploads(?:/|$) - [L]

# Layani file/folder asli secara langsung.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback routing React untuk URL seperti /admin dan /open-trip/123.
RewriteRule ^ index.html [L]
